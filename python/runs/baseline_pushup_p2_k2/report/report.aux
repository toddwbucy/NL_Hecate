\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Training loss with k=1 baseline overlay (dashed). The k=2 model starts at the donor's final loss (2.79) but immediately regresses to $\sim $3.5 during warmup.}}{4}{figure.caption.4}\protected@file@percent }
\newlabel{fig:loss}{{1}{4}{Training loss with k=1 baseline overlay (dashed). The k=2 model starts at the donor's final loss (2.79) but immediately regresses to $\sim $3.5 during warmup}{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Heavily-smoothed loss comparison. The red shaded area shows the regression zone where k=2 exceeds k=1 loss. The k=2 model \textbf  {never} reaches the k=1 floor.}}{5}{figure.caption.5}\protected@file@percent }
\newlabel{fig:loss_compare}{{2}{5}{Heavily-smoothed loss comparison. The red shaded area shows the regression zone where k=2 exceeds k=1 loss. The k=2 model \textbf {never} reaches the k=1 floor}{figure.caption.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Training perplexity (log scale). k=2 (red) sits consistently above k=1 (blue dashed).}}{5}{figure.caption.6}\protected@file@percent }
