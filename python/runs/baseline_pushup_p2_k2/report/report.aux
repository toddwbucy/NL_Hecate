\@writefile{toc}{\contentsline {section}{\numberline {5}Gradient Analysis}{6}{section.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}Global and Per-Block Gradient Norms}{6}{subsection.5.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Top: global gradient norm (k=2 solid, k=1 dashed). Bottom: per-block gradient norms. Block~0 still dominates, but with lower magnitude than at k=1.}}{6}{figure.caption.7}\protected@file@percent }
\newlabel{fig:gnorms}{{4}{6}{Top: global gradient norm (k=2 solid, k=1 dashed). Bottom: per-block gradient norms. Block~0 still dominates, but with lower magnitude than at k=1}{figure.caption.7}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Inner-Loop Gradient Norms: k=1 vs k=2}{7}{subsection.5.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces L0 inner-loop gradient norms compared side-by-side. Left: k=1 baseline shows clear Block~0 dominance with strong growth (0.001 $\to $ 0.38). Right: k=2 shows flatter trajectories, especially for Block~0.}}{7}{figure.caption.8}\protected@file@percent }
\newlabel{fig:l0}{{5}{7}{L0 inner-loop gradient norms compared side-by-side. Left: k=1 baseline shows clear Block~0 dominance with strong growth (0.001 $\to $ 0.38). Right: k=2 shows flatter trajectories, especially for Block~0}{figure.caption.8}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Depth Specialization}{7}{subsection.5.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Block gradient norm CV. k=2 (red) trends \textbf  {downward} relative to k=1 (blue), ending at 0.29 vs 0.39 --- indicating \emph  {less} depth specialization.}}{7}{figure.caption.9}\protected@file@percent }
\newlabel{fig:cv}{{6}{7}{Block gradient norm CV. k=2 (red) trends \textbf {downward} relative to k=1 (blue), ending at 0.29 vs 0.39 --- indicating \emph {less} depth specialization}{figure.caption.9}{}}
