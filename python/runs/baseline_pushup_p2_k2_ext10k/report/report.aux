\@writefile{toc}{\contentsline {section}{\numberline {4}Loss: Full Experimental Context}{2}{section.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Loss comparison across all four experiments. The extension (dark red) continues the push-up's plateau from steps 20K--30K. The fresh k=2 (green dashed) is already converging faster from random init.}}{2}{figure.caption.4}\protected@file@percent }
\newlabel{fig:loss_all}{{1}{2}{Loss comparison across all four experiments. The extension (dark red) continues the push-up's plateau from steps 20K--30K. The fresh k=2 (green dashed) is already converging faster from random init}{figure.caption.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Extension run loss detail. One major spike at step 24K (loss=5.58) correlates with L1 theta instability (see Section~\ref {sec:theta}).}}{3}{figure.caption.5}\protected@file@percent }
