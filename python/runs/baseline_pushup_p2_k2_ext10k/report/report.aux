\@writefile{toc}{\contentsline {section}{\numberline {5}Gradient Analysis}{4}{section.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Per-block gradient norms and CV during the extension. CV hovers at $\sim $0.30, below the 0.3 threshold for meaningful specialization.}}{4}{figure.caption.6}\protected@file@percent }
\newlabel{fig:gnorms}{{3}{4}{Per-block gradient norms and CV during the extension. CV hovers at $\sim $0.30, below the 0.3 threshold for meaningful specialization}{figure.caption.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces L0 inner-loop gradient norms. Block~0 dominates ($\sim $0.35) but no growth trend is visible --- the memory mechanism has stagnated.}}{4}{figure.caption.7}\protected@file@percent }
\newlabel{fig:l0}{{4}{4}{L0 inner-loop gradient norms. Block~0 dominates ($\sim $0.35) but no growth trend is visible --- the memory mechanism has stagnated}{figure.caption.7}{}}
\@writefile{toc}{\contentsline {section}{\numberline {6}Gate Diagnostics: The Oscillation Problem}{5}{section.6}\protected@file@percent }
\newlabel{sec:theta}{{6}{5}{Gate Diagnostics: The Oscillation Problem}{section.6}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.1}Theta (Inner-Loop Learning Rate): Oscillation vs Convergence}{5}{subsection.6.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Theta (inner-loop LR) for L0 and L1 across two blocks. \textbf  {Left:} Push-up extension --- L1 theta oscillates wildly, especially in Block~3. \textbf  {Right:} Fresh k=2 --- L0 rises to $\sim $0.9, L1 stays low ($<$0.2). Shaded area shows L0-L1 gap.}}{5}{figure.caption.8}\protected@file@percent }
\newlabel{fig:theta}{{5}{5}{Theta (inner-loop LR) for L0 and L1 across two blocks. \textbf {Left:} Push-up extension --- L1 theta oscillates wildly, especially in Block~3. \textbf {Right:} Fresh k=2 --- L0 rises to $\sim $0.9, L1 stays low ($<$0.2). Shaded area shows L0-L1 gap}{figure.caption.8}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Block~3 L1 theta: push-up extension showing extreme oscillation.}}{5}{table.caption.9}\protected@file@percent }
\newlabel{tab:theta_osc}{{4}{5}{Block~3 L1 theta: push-up extension showing extreme oscillation}{table.caption.9}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Alpha (Retention): No Timescale Separation}{6}{subsection.6.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Alpha (retention) for Block~1. \textbf  {Left:} Push-up extension --- L0 and L1 alpha overlap with no separation trend. \textbf  {Right:} Fresh k=2 --- alpha values cross and wander but show slightly more range.}}{6}{figure.caption.10}\protected@file@percent }
\newlabel{fig:alpha}{{6}{6}{Alpha (retention) for Block~1. \textbf {Left:} Push-up extension --- L0 and L1 alpha overlap with no separation trend. \textbf {Right:} Fresh k=2 --- alpha values cross and wander but show slightly more range}{figure.caption.10}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}Eta (Output Gate): Moderate Separation}{7}{subsection.6.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Eta (output gate) for Block~1. Both experiments show L0 eta $>$ L1 eta, with the fresh k=2 exhibiting wider separation.}}{7}{figure.caption.11}\protected@file@percent }
\newlabel{fig:eta}{{7}{7}{Eta (output gate) for Block~1. Both experiments show L0 eta $>$ L1 eta, with the fresh k=2 exhibiting wider separation}{figure.caption.11}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.4}DGD Update Magnitude Ratio}{7}{subsection.6.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces L0/L1 DGD delta norm ratio. Push-up ext (circles) is stuck at $\sim $1.3. Fresh k=2 (squares) reaches 2.5--3.5 --- L0 makes much larger memory updates.}}{7}{figure.caption.12}\protected@file@percent }
\newlabel{fig:dgd}{{8}{7}{L0/L1 DGD delta norm ratio. Push-up ext (circles) is stuck at $\sim $1.3. Fresh k=2 (squares) reaches 2.5--3.5 --- L0 makes much larger memory updates}{figure.caption.12}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.5}Output Gradient Norms: Identical in Both Experiments}{8}{subsection.6.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces L0/L1 output gradient norm ratio = 1.000 in both experiments. This is a structural property of MAG composition, not a bug.}}{8}{figure.caption.13}\protected@file@percent }
\newlabel{fig:outgrad}{{9}{8}{L0/L1 output gradient norm ratio = 1.000 in both experiments. This is a structural property of MAG composition, not a bug}{figure.caption.13}{}}
