\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Left: Three-way comparison. The k=3 push-up (orange) starts higher due to the push-up spike but reaches comparable loss to the k=2 130K run by step $\sim $40K. Right: k=3 trajectory alone.}}{5}{figure.caption.5}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces k=3 vs k=2 comparison at matched step counts.}}{5}{table.caption.6}\protected@file@percent }
