\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Eta evolution. All three levels maintain high eta ($>$0.93) across all blocks. No L1 eta collapse is observed, unlike the k=2 130K run.}}{10}{figure.caption.18}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Eta by level. L0 saturates to 1.0. L1 and L2 both maintain high eta ($>$0.93).}}{10}{figure.caption.19}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Eta at step 95K.}}{10}{table.caption.20}\protected@file@percent }
