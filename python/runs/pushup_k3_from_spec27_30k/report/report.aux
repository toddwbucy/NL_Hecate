\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Global gradient norm and block CV. Gnorm settles to $\sim $2.0--2.5. Block CV drops from 0.38 to 0.20, crossing the specialization threshold around step 15K.}}{5}{figure.caption.7}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Per-block gradient norms. Block 0 dominates, consistent with all k=2 runs.}}{6}{figure.caption.8}\protected@file@percent }
