\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Alpha evolution. All three levels trend toward the 0.80 floor. L2 in Blocks 2/3 stays elevated (0.94--0.96) --- these blocks retain more L2 memory.}}{9}{figure.caption.15}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Alpha floor-pinning detail. Most block/level combinations hit the floor by step 50K.}}{9}{figure.caption.16}\protected@file@percent }
