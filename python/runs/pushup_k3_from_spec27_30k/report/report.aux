\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Theta evolution for all three levels across 4 blocks. L0 (blue) saturates to 1.0. L1 (orange) is bimodal: high in Blocks 1/2/3, low in Block~0. L2 (green) stays near zero everywhere.}}{7}{figure.caption.12}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Theta organized by level. Left: L0 theta --- all blocks near 1.0. Center: L1 theta --- Block~2 reaches 0.81, Block~1 and Block~3 oscillate around 0.5--1.0, Block~0 stays below 0.04. Right: L2 theta --- all blocks below 0.05.}}{8}{figure.caption.13}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Theta at step 95K by block and level. The three-tier hierarchy is clear.}}{8}{table.caption.14}\protected@file@percent }
