{
  "description": "Gate activation warmup diagnostic — k=4 Delta Rule + 3-phase gate warmup on C4 (995M tokens, Llama tokenizer). Task: task_fd444d.",
  "notes": "See specs/infrastructure/09_gate_warmup.md. Phase 2 decays gate_warmup.theta_floor_init → 0 over gate_warmup.gate_warmup_decay_steps. Falsification checks L2/L3 θ against gate_warmup.l2_theta_threshold / l3_theta_threshold.",
  "model": {
    "d_model": 256,
    "num_heads": 4,
    "seq_len": 512,
    "window_size": 256,
    "vocab_size": 32000,
    "k": 4,
    "memory_rule": "delta",
    "composition": "mag",
    "memory_reset": "carry_forward",
    "theta_floor": [0.0, 0.0, 0.0, 0.0],
    "theta_ceil": [1.0, 1.0, 1.0, 1.0],
    "m_norm_max": [100.0, 100.0, 100.0, 100.0]
  },
  "gate_warmup": {
    "theta_floor_init": [0.0, 0.0, 0.005, 0.001],
    "gate_warmup_decay_steps": 10000,
    "falsification_step": 20000,
    "l2_theta_threshold": 0.005,
    "l3_theta_threshold": 0.001
  },
  "build": {
    "lr": 3e-4,
    "steps": 25000,
    "seed": 42,
    "optimizer": "adamw_gpu",
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.999,
    "warmup_steps": 500,
    "max_grad_norm": 1.0,
    "log_every": 250,
    "eval_every": 250,
    "eval_max_chunks": 50,
    "save_every": 5000,
    "save_path": "checkpoints/gate_warmup_diagnostic.safetensors",
    "log_file": "python/runs/gate_warmup_diagnostic.jsonl"
  },
  "data": {
    "path": "python/data/c4",
    "format": "sharegpt"
  }
}
