{
  "description": "Stack-up Phase 4: Extend k=3 to k=4. Trained L0+L1+L2 stay, fresh L3 added at top (every-512 frequency). 10K steps.",
  "model": {
    "k": 4,
    "d_model": 512,
    "num_heads": 8,
    "seq_len": 512,
    "window_size": 512,
    "vocab_size": 32000,
    "memory_rule": "titans",
    "composition": "mag",
    "momentum_kind": "ema",
    "momentum_d_hidden": 0
  },
  "build": {
    "lr": 0.0006,
    "steps": 10000,
    "optimizer": "adamw_gpu",
    "warmup_steps": 500,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.999,
    "max_grad_norm": 1.0,
    "save_path": "checkpoints/stack_up_phase4_k4.safetensors",
    "save_every": 2500,
    "log_every": 10,
    "eval_every": 500,
    "eval_max_chunks": 50,
    "log_file": "runs/stack_up_phase4_k4.jsonl",
    "load": "checkpoints/stack_up_phase3_k3.safetensors",
    "extend_k": 4,
    "stack_up": true
  },
  "data": {
    "path": "data/dolmino_100b",
    "format": "sharegpt"
  }
}
