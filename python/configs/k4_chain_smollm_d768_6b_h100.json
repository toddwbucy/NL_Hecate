{
    "description": "k=4 chain d=768 12-head 6-block on Dolmino. H100 per-head memory benchmark.",
    "model": {
        "d_model": 768,
        "num_heads": 12,
        "seq_len": 512,
        "window_size": 512,
        "vocab_size": 49152,
        "memory_rule": "titans",
        "composition": "mag",
        "hope_variant": "chained",
        "k": 4,
        "chunk_sizes": [1, 8, 64, 512],
        "m_norm_max": [100.0, 100.0, 100.0, 100.0],
        "error_clip": [0.0, 0.0, 0.0, 0.0],
        "residual": true,
        "n_blocks": 6,
        "parallel_strategy": "none",
        "memory_reset": "periodic",
        "tape_multiplier": 1,
        "tape_strategies": ["exact", "proxy", "proxy", "proxy"]
    },
    "build": {
        "optimizer": "adamw_gpu_stacked",
        "lr": 0.0003,
        "steps": 200000,
        "warmup_steps": 500,
        "weight_decay": 0.1,
        "beta1": 0.9,
        "beta2": 0.999,
        "max_grad_norm": 1.0,
        "alpha_floor": [0.0, 0.0, 0.0, 0.0],
        "theta_ceil": [1.0, 1.0, 1.0, 1.0],
        "batch_size": 1,
        "log_every": 8,
        "eval_every": 1000,
        "save_every": 5120,
        "tape_every": 1000,
        "tape_device": "gpu",
        "profile_step": 1024,
        "gpu": true,
        "seed": 42,
        "run_dir": "runs/k4_chain_dolmino_d768_6b_h100",
        "save_path": "runs/k4_chain_dolmino_d768_6b_h100/checkpoints/model.safetensors",
        "log_file": "runs/k4_chain_dolmino_d768_6b_h100/metrics.jsonl"
    },
    "data": {
        "path": "data/dolmino_100b",
        "format": "dolmino"
    }
}
