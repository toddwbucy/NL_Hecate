{
  "description": "Dolmino-Mix 100B — k=4 CMS Delta Rule cold-start build (d=512, ingredient1 common_crawl). 100K steps on 1B-token dolmino dataset. eval_every=1028 (2×L3+4), save_every=5126 (10×L3+6). Delta series baseline.",
  "model": {
    "d_model": 512,
    "num_heads": 8,
    "seq_len": 512,
    "window_size": 512,
    "vocab_size": 32000,
    "k": 4,
    "chunk_sizes": [1, 8, 64, 512],
    "memory_rule": "delta",
    "composition": "mag",
    "memory_reset": "carry_forward",
    "theta_floor": [0.0, 0.0, 0.0, 0.0]
  },
  "build": {
    "lr": 0.0006,
    "steps": 100000,
    "optimizer": "adamw_gpu",
    "warmup_steps": 1000,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.999,
    "max_grad_norm": 1.0,
    "save_path": "checkpoints/dolmino_100b_k4.safetensors",
    "save_every": 5126,
    "log_every": 10,
    "eval_every": 1028,
    "eval_max_chunks": 50,
    "tape_every": 1000,
    "probe_max_tokens": 20,
    "probe_prompts": 1,
    "log_file": "runs/dolmino_100b_k4.jsonl"
  },
  "data": {
    "path": "data/dolmino_100b",
    "format": "sharegpt"
  }
}
