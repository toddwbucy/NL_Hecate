{
  "description": "H100 Push-up Phase 3: Extend k=2->k=3. Trained levels shift up, fresh L0 inserted. 10K steps.",
  "model": {
    "k": 3,
    "d_model": 1024,
    "num_heads": 16,
    "seq_len": 512,
    "window_size": 512,
    "vocab_size": 32000,
    "memory_rule": "titans",
    "composition": "mag",
    "momentum_kind": "ema",
    "momentum_d_hidden": 0,
    "parallel_strategy": "tnt_hierarchical",
    "tnt_global_chunk_size": 64,
    "tnt_local_chunk_size": 8
  },
  "build": {
    "lr": 0.0003,
    "steps": 10000,
    "optimizer": "adamw_gpu",
    "warmup_steps": 500,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.999,
    "max_grad_norm": 1.0,
    "save_path": "checkpoints/h100_push_up_phase3_k3.safetensors",
    "save_every": 2500,
    "log_every": 10,
    "eval_every": 500,
    "eval_max_chunks": 50,
    "log_file": "runs/h100_push_up_phase3_k3.jsonl",
    "load": "checkpoints/h100_push_up_phase2_k2.safetensors",
    "extend_k": 3,
    "push_up": true
  },
  "data": {
    "path": "data/dolmino_100b",
    "format": "sharegpt"
  }
}
