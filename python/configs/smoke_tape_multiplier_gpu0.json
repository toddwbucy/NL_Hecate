{
    "description": "Smoke test: tape_multiplier=1 boundary-only checkpoints. 100 steps. GPU 0.",
    "model": {
        "d_model": 512,
        "num_heads": 8,
        "seq_len": 512,
        "window_size": 512,
        "vocab_size": 50257,
        "memory_rule": "titans",
        "composition": "mag",
        "k": 4,
        "chunk_sizes": [1, 8, 64, 512],
        "m_norm_max": [0.0, 0.0, 0.0, 0.0],
        "error_clip": [0.0, 0.0, 0.0, 0.0],
        "residual": true,
        "n_blocks": 4,
        "parallel_strategy": "tnt_hierarchical",
        "tnt_global_chunk_size": 64,
        "tnt_local_chunk_size": 8,
        "memory_reset": "periodic",
        "tape_multiplier": 1
    },
    "build": {
        "lr": 0.0003,
        "steps": 100,
        "optimizer": "adamw_gpu_stacked",
        "warmup_steps": 10,
        "weight_decay": 0.1,
        "beta1": 0.9,
        "beta2": 0.999,
        "max_grad_norm": 1.0,
        "alpha_floor": [0.8, 0.8, 0.8, 0.8],
        "theta_ceil": [1.0, 1.0, 1.0, 1.0],
        "batch_size": 1,
        "log_every": 10,
        "eval_every": 50,
        "save_every": 0,
        "tape_device": "off",
        "gpu": true,
        "seed": 42
    },
    "data": {
        "path": "data/dolmino_100b",
        "format": "dolmino"
    }
}
