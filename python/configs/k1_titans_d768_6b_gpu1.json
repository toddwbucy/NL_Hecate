{
    "description": "k=1 pure Titans ablation: 8 blocks, d=768, SmolLM corpus. Controlled comparison vs k2_chain_smollm_d768_6b (GPU0). Same optimizer, data, vocab, seed.",
    "model": {
        "d_model": 768,
        "num_heads": 12,
        "seq_len": 512,
        "window_size": 512,
        "vocab_size": 49152,
        "memory_rule": "titans",
        "composition": "mag",
        "hope_variant": "freq_gated",
        "k": 1,
        "chunk_sizes": [1],
        "m_norm_max": [100.0],
        "error_clip": [0.0],
        "residual": true,
        "n_blocks": 6,
        "parallel_strategy": "tnt_hierarchical",
        "tnt_global_chunk_size": 64,
        "tnt_local_chunk_size": 8,
        "memory_reset": "periodic",
        "tape_multiplier": 1,
        "tape_strategies": ["exact"]
    },
    "build": {
        "optimizer": "adamw_gpu_stacked",
        "lr": 0.0003,
        "steps": 200000,
        "warmup_steps": 500,
        "weight_decay": 0.1,
        "beta1": 0.9,
        "beta2": 0.999,
        "max_grad_norm": 1.0,
        "alpha_floor": [0.0],
        "theta_ceil": [1.0],
        "batch_size": 1,
        "log_every": 8,
        "save_every": 1024,
        "tape_device": "gpu",
        "profile_step": 1024,
        "gpu": true,
        "seed": 42,
        "run_dir": "runs/k1_titans_d768_6b",
        "save_path": "runs/k1_titans_d768_6b/checkpoints/model.safetensors",
        "log_file": "runs/k1_titans_d768_6b/metrics.jsonl"
    },
    "data": {
        "path": "/bulk-store/training-datasets/ready-to-use/olympian_001_smollm_corpus",
        "format": "smollm"
    }
}
