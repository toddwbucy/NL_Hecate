{
  "model": {
    "d_model": 4096,
    "num_heads": 32,
    "head_dim": 128,
    "seq_len": 512,
    "window_size": 512,
    "vocab_size": 32000,
    "k": 4,
    "chunk_sizes": [1, 8, 64, 512],
    "memory_rule": "swiglu_mlp",
    "composition": "mag",
    "intermediate_size": 14336
  },
  "build": {
    "lr": 0.0002,
    "steps": 50000,
    "optimizer": "adamw_gpu",
    "warmup_steps": 1000,
    "weight_decay": 0.1,
    "max_grad_norm": 1.0,
    "save_path": "checkpoints/llama8b_pretrain.safetensors",
    "save_every": 5000,
    "log_every": 10,
    "eval_every": 5000,
    "eval_max_chunks": 50
  },
  "data": {
    "path": "data/fineweb_edu",
    "format": "sharegpt"
  },
  "donor_layers": [0, 8, 16, 24],
  "donor_weights": "checkpoints/llama8b_mlp_donor.pt",
  "notes": "d=4096 NLM matching Llama-3-8B MLP dimensions. GPU0 pretrain baseline. Establishes: throughput, loss trajectory, feasibility at 8B-scale MLP priors on single A6000."
}
