{
    "description": "k=2 d=768 12-head 6-block on Dolmino. Exact+proxy tape. Tests whether d=512 loss plateau (~6.0) was capacity-limited. GPU 1.",
    "model": {
        "d_model": 768,
        "num_heads": 12,
        "seq_len": 512,
        "window_size": 512,
        "vocab_size": 49152,
        "memory_rule": "titans",
        "composition": "mag",
        "k": 2,
        "chunk_sizes": [1, 8],
        "m_norm_max": [100.0, 100.0],
        "error_clip": [0.0, 0.0],
        "residual": true,
        "n_blocks": 6,
        "parallel_strategy": "tnt_hierarchical",
        "tnt_global_chunk_size": 64,
        "tnt_local_chunk_size": 8,
        "memory_reset": "periodic",
        "tape_multiplier": 1,
        "tape_strategies": ["exact", "proxy"]
    },
    "build": {
        "optimizer": "adamw_gpu_stacked",
        "lr": 0.0003,
        "steps": 200000,
        "warmup_steps": 500,
        "weight_decay": 0.1,
        "beta1": 0.9,
        "beta2": 0.999,
        "max_grad_norm": 1.0,
        "alpha_floor": [0.0, 0.0],
        "theta_ceil": [1.0, 1.0],
        "batch_size": 1,
        "log_every": 8,
        "eval_every": 1000,
        "save_every": 5000,
        "run_dir": "runs/k2_dolmino_d768",
        "tape_every": 1000,
        "tape_device": "gpu",
        "gpu": true,
        "seed": 42
    },
    "data": {
        "path": "data/dolmino_100b",
        "format": "dolmino"
    }
}
