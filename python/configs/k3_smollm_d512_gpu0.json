{
    "description": "k=3 d=512 8-head 4-block on SmolLM corpus. Exact tape on L0, proxy on L1/L2. GPU 0.",
    "model": {
        "d_model": 512,
        "num_heads": 8,
        "seq_len": 512,
        "window_size": 512,
        "vocab_size": 49152,
        "memory_rule": "titans",
        "composition": "mag",
        "k": 3,
        "chunk_sizes": [1, 8, 64],
        "m_norm_max": [100.0, 100.0, 100.0],
        "error_clip": [0.0, 0.0, 0.0],
        "residual": true,
        "n_blocks": 4,
        "parallel_strategy": "tnt_hierarchical",
        "tnt_global_chunk_size": 64,
        "tnt_local_chunk_size": 8,
        "memory_reset": "periodic",
        "tape_multiplier": 1,
        "tape_strategies": ["exact", "proxy", "proxy"]
    },
    "build": {
        "optimizer": "adamw_gpu_stacked",
        "lr": 0.0003,
        "steps": 200000,
        "warmup_steps": 500,
        "weight_decay": 0.1,
        "beta1": 0.9,
        "beta2": 0.999,
        "max_grad_norm": 1.0,
        "alpha_floor": [0.0, 0.0, 0.0],
        "theta_ceil": [1.0, 1.0, 1.0],
        "batch_size": 1,
        "log_every": 8,
        "eval_every": 1024,
        "save_every": 5120,
        "run_dir": "runs/k3_smollm_d512",
        "tape_every": 1024,
        "tape_device": "gpu",
        "gpu": true,
        "seed": 42
    },
    "data": {
        "path": "/bulk-store/training-datasets/ready-to-use/olympian_001_smollm_corpus",
        "format": "smollm"
    }
}
