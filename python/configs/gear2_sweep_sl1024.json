{
    "description": "Gear-2 sweep: seq_len=1024, batch_size=4. Selective reset [1,8,64,512]. Measures L1/L2 activation at 2x baseline tape length.",
    "model": {
        "d_model": 1024,
        "num_heads": 32,
        "seq_len": 1024,
        "window_size": 512,
        "vocab_size": 49152,
        "memory_rule": "titans",
        "composition": "mag",
        "hope_variant": "chained",
        "k": 4,
        "chunk_sizes": [1, 8, 64, 512],
        "m_norm_max": [100.0, 100.0, 100.0, 100.0],
        "error_clip": [0.0, 0.0, 0.0, 0.0],
        "residual": true,
        "n_blocks": 4,
        "parallel_strategy": "tnt_hierarchical",
        "tnt_global_chunk_size": 64,
        "tnt_local_chunk_size": 8,
        "memory_reset": "periodic",
        "reset_intervals": [1, 8, 64, 512],
        "tape_multiplier": 1,
        "tape_strategies": ["exact", "proxy", "proxy", "proxy"]
    },
    "build": {
        "optimizer": "adamw_gpu_stacked",
        "lr": 0.0003,
        "steps": 100000,
        "warmup_steps": 500,
        "weight_decay": 0.1,
        "beta1": 0.9,
        "beta2": 0.999,
        "max_grad_norm": 1.0,
        "alpha_floor": [0.0, 0.0, 0.0, 0.0],
        "theta_ceil": [1.0, 1.0, 1.0, 1.0],
        "batch_size": 4,
        "log_every": 8,
        "save_every": 1000,
        "tape_device": "gpu",
        "gpu": true,
        "seed": 42,
        "run_dir": "runs/gear2_sweep_sl1024",
        "save_path": "runs/gear2_sweep_sl1024/checkpoints/model.safetensors"
    },
    "data": {
        "path": "data/dolmino_100b",
        "format": "dolmino"
    }
}
