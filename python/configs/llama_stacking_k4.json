{
  "model": {
    "d_model": 2048,
    "num_heads": 32,
    "head_dim": 64,
    "seq_len": 512,
    "window_size": 512,
    "vocab_size": 128256,
    "k": 4,
    "chunk_sizes": [1, 8, 64, 512],
    "memory_rule": "swiglu_mlp",
    "composition": "mag",
    "intermediate_size": 8192
  },
  "build": {
    "lr": 0.0003,
    "steps": 50000,
    "optimizer": "adamw_gpu",
    "warmup_steps": 500,
    "weight_decay": 0.1,
    "max_grad_norm": 1.0,
    "save_every": 5000,
    "log_every": 10,
    "eval_every": 5000,
    "eval_max_chunks": 50,
    "seed": 42
  },
  "data": {
    "path": "data/fineweb_edu_llama3",
    "format": "byte"
  },
  "donor_layers": [0, 5, 10, 15],
  "donor_weights": "checkpoints/llama_mlp_donor.pt",
  "notes": "HOPE §7.3 ad-hoc level stacking: Llama-3.2-1B MLP blocks as CMS levels. GPU1 target."
}
