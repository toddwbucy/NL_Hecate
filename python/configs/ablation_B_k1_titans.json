{
  "description": "ABLATION-B: k=1 TitansLMM + MAG — single-level DGD baseline",
  "notes": "Run B of 4. Single CMS level (L0, every-token), TitansLMM memory rule (DGD / L2 regression inner loop), MAG composition. Tests whether any memory benefit exists at k=1 before testing multi-scale. See specs/infrastructure/05_ablation_study.md.",

  "model": {
    "d_model": 512,
    "num_heads": 8,
    "seq_len": 512,
    "window_size": 512,
    "vocab_size": 32000,
    "memory_enabled": true,
    "k": 1,
    "chunk_sizes": [1],
    "memory_rule": "titans",
    "composition": "mag",
    "projection_kind": "adaptive",
    "self_generated_values": false,
    "self_ref_chunk_size": 1,
    "momentum_kind": "none",
    "momentum_d_hidden": 0
  },

  "build": {
    "lr": 0.0004,
    "steps": 100000,
    "optimizer": "adamw_gpu",
    "warmup_steps": 200,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.999,
    "max_grad_norm": 1.0,
    "seed": 42,
    "save_path": "checkpoints/ablation_B.json",
    "save_every": 5000,
    "log_every": 10,
    "eval_every": 1000,
    "eval_max_chunks": 100,
    "log_file": "runs/ablation_B.jsonl"
  },

  "data": {
    "path": "data/c4",
    "format": "sharegpt"
  },

  "m_norm_max": [100.0]
}
