{
  "description": "H100 TNT 100K production run — d=1024, k=4, Titans MAG with TNT chunkwise parallelization. N=8 local memories per shard (C_G=64, C_L=8). Based on 200-step benchmark (946 tok/s). v2: lr halved to 0.0003 (sqrt(d) scaling from d=512), m_norm_max tightened to 50.0 after NaN at step 3220 in v1. Dolmino-100B dataset.",
  "model": {
    "d_model": 1024,
    "num_heads": 16,
    "seq_len": 512,
    "window_size": 1024,
    "vocab_size": 32000,
    "k": 4,
    "chunk_sizes": [1, 8, 64, 512],
    "memory_rule": "titans",
    "composition": "mag",
    "momentum_kind": "none",
    "momentum_d_hidden": 0,
    "theta_floor": [0.0, 0.0, 0.0, 0.0],
    "parallel_strategy": "tnt_hierarchical",
    "tnt_global_chunk_size": 64,
    "tnt_local_chunk_size": 8
  },
  "build": {
    "lr": 0.0003,
    "steps": 100000,
    "optimizer": "adamw_gpu",
    "warmup_steps": 1000,
    "weight_decay": 0.1,
    "beta1": 0.9,
    "beta2": 0.999,
    "max_grad_norm": 1.0,
    "save_path": "checkpoints/h100_d1024_tnt_100k.safetensors",
    "save_every": 5000,
    "log_every": 10,
    "eval_every": 2500,
    "eval_max_chunks": 50,
    "tape_every": 0,
    "probe_max_tokens": 0,
    "probe_prompts": 0,
    "log_file": "runs/h100_d1024_tnt_100k.jsonl"
  },
  "gate_warmup": {
    "falsification_step": 0
  },
  "data": {
    "path": "data/dolmino_100b",
    "format": "sharegpt"
  },
  "m_norm_max": [50.0, 50.0, 50.0, 50.0]
}
